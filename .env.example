# Anthropic API key for the AI scorer (server-only)
ANTHROPIC_API_KEY=

# Oracle keypair JSON array, e.g. "[12,34,...]" (server-only secret)
# Generate locally with: solana-keygen new -o oracle-keypair.json --no-bip39-passphrase
# Then: cat oracle-keypair.json   <-- paste the bracketed array here
ORACLE_KEYPAIR_JSON=

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# Public-facing values (sent to the browser — DO NOT put secrets here)
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
